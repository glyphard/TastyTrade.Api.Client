<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
  </PropertyGroup>

  <PropertyGroup>
    <PackageId>TastyTrade.Api.Client</PackageId>
    <PackageVersion>1.0.4</PackageVersion>
    <Authors>glyphard</Authors>
    <Description>A C# client library for the TastyTrade API, supporting authentication, account management, order placement, streaming, and more.</Description>
    <PackageTags>tastytrade;trading;api;client;options;stocks</PackageTags>
    <PackageProjectUrl>https://github.com/glyphard/TastyTrade.Api.Client</PackageProjectUrl>
    <RepositoryUrl>https://github.com/glyphard/TastyTrade.Api.Client</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
  </PropertyGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="DxFeed.Graal.Net" Version="2.4.1" />
    <PackageReference Include="System.Text.Json" Version="9.0.0" />
  </ItemGroup>

</Project>
